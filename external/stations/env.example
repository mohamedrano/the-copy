# ===========================================
# إعدادات البيئة - ملف المثال
# انسخ هذا الملف إلى .env وقم بتعديل القيم
# ===========================================

# ===========================================
# إعدادات التطبيق الأساسية
# ===========================================
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# ===========================================
# إعدادات قاعدة البيانات
# ===========================================
DATABASE_URL=postgresql://username:password@localhost:5432/stations_db

# ===========================================
# إعدادات Gemini AI
# ===========================================
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# إعدادات الأمان
# ===========================================
# مفاتيح API صالحة (مفصولة بفاصلة)
VALID_API_KEYS=dev-key-123,prod-key-456,admin-key-789

# سر الجلسات (يجب أن يكون عشوائياً وقوياً)
SESSION_SECRET=your_very_strong_session_secret_here_minimum_32_characters

# أصول مسموحة (مفصولة بفاصلة)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com

# ===========================================
# إعدادات Redis (اختياري - للتخزين المؤقت)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ===========================================
# إعدادات المراقبة والتسجيل
# ===========================================
LOG_LEVEL=info
SENTRY_DSN=

# ===========================================
# إعدادات Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_ANALYSIS_RATE_LIMIT_MAX=10
AI_ANALYSIS_RATE_LIMIT_WINDOW_MS=3600000

# ===========================================
# إعدادات التخزين المؤقت
# ===========================================
CACHE_TTL_SECONDS=3600
ENABLE_CACHE=true

# ===========================================
# إعدادات قاعدة البيانات المتقدمة
# ===========================================
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_ACQUIRE_TIMEOUT_MS=60000

# ===========================================
# إعدادات الأمان المتقدمة
# ===========================================
# مدة انتهاء صلاحية JWT (بالثواني)
JWT_EXPIRES_IN=86400

# مدة انتهاء صلاحية الجلسة (بالميلي ثانية)
SESSION_MAX_AGE=86400000

# تفعيل HTTPS في الإنتاج
FORCE_HTTPS=false

# ===========================================
# إعدادات التطوير
# ===========================================
# تفعيل وضع التطوير
DEBUG=false

# تفعيل تسجيل مفصل
VERBOSE_LOGGING=false

# ===========================================
# إعدادات الإنتاج
# ===========================================
# تفعيل ضغط الاستجابات
ENABLE_COMPRESSION=true

# تفعيل تحسين الأداء
ENABLE_PERFORMANCE_OPTIMIZATIONS=true

# ===========================================
# إعدادات النسخ الاحتياطي
# ===========================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

