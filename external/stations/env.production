# ===========================================
# إعدادات البيئة للإنتاج - نظام Stations
# ===========================================

# ===========================================
# إعدادات التطبيق الأساسية
# ===========================================
NODE_ENV=production
PORT=5000
API_BASE_URL=https://yourdomain.com

# ===========================================
# إعدادات قاعدة البيانات
# ===========================================
DATABASE_URL=postgresql://stations_user:STRONG_PASSWORD_HERE@localhost:5432/stations_production
DB_PASSWORD=STRONG_PASSWORD_HERE

# ===========================================
# إعدادات Gemini AI
# ===========================================
GEMINI_API_KEY=your_production_gemini_api_key_here

# ===========================================
# إعدادات الأمان
# ===========================================
# مفاتيح API صالحة (مفصولة بفاصلة)
VALID_API_KEYS=prod-api-key-1,prod-api-key-2,prod-api-key-3

# سر الجلسات (يجب أن يكون عشوائياً وقوياً - 32+ حرف)
SESSION_SECRET=your_very_strong_session_secret_here_minimum_32_characters_long

# أصول مسموحة (مفصولة بفاصلة)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# إعدادات Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://localhost:6379

# ===========================================
# إعدادات المراقبة والتسجيل
# ===========================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_here

# ===========================================
# إعدادات Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_ANALYSIS_RATE_LIMIT_MAX=10
AI_ANALYSIS_RATE_LIMIT_WINDOW_MS=3600000

# ===========================================
# إعدادات التخزين المؤقت
# ===========================================
CACHE_TTL_SECONDS=3600
ENABLE_CACHE=true

# ===========================================
# إعدادات قاعدة البيانات المتقدمة
# ===========================================
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_ACQUIRE_TIMEOUT_MS=60000

# ===========================================
# إعدادات الأمان المتقدمة
# ===========================================
JWT_EXPIRES_IN=86400
SESSION_MAX_AGE=86400000
FORCE_HTTPS=true

# ===========================================
# إعدادات الإنتاج
# ===========================================
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_COMPRESSION=true
ENABLE_PERFORMANCE_OPTIMIZATIONS=true

# ===========================================
# إعدادات النسخ الاحتياطي
# ===========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ===========================================
# إعدادات Docker (إذا تم استخدام Docker)
# ===========================================
COMPOSE_PROJECT_NAME=stations
COMPOSE_FILE=docker-compose.production.yml

# ===========================================
# إعدادات SSL (إذا تم استخدام SSL)
# ===========================================
SSL_CERT_PATH=/etc/nginx/ssl/certificate.crt
SSL_KEY_PATH=/etc/nginx/ssl/private.key

# ===========================================
# إعدادات المراقبة
# ===========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=false
GRAFANA_PORT=3000

# ===========================================
# إعدادات النسخ الاحتياطي
# ===========================================
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=your-access-key
BACKUP_S3_SECRET_KEY=your-secret-key

# ===========================================
# إعدادات البريد الإلكتروني (إذا تم استخدامه)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ===========================================
# إعدادات إضافية
# ===========================================
# تعيين المنطقة الزمنية
TZ=UTC

# تعيين اللغة
LANG=en_US.UTF-8

# تعيين الحد الأقصى للذاكرة
NODE_OPTIONS=--max-old-space-size=1024

# تعيين timeout للطلبات
REQUEST_TIMEOUT=30000

# تعيين الحد الأقصى لحجم الطلب
MAX_REQUEST_SIZE=10mb

