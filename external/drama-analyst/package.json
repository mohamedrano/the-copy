{
  "name": "the-copy-drama-analyst",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t drama-analyst -f Dockerfile.dev --target production .",
    "docker:run": "docker run -p 80:80 -p 3001:3001 drama-analyst",
    "docker:dev": "docker-compose up --build",
    "docker:prod": "docker-compose -f docker-compose.yml --profile production up -d --build",
    "deploy:vercel": "./scripts/deploy.sh latest vercel",
    "deploy:netlify": "./scripts/deploy.sh latest netlify",
    "deploy:github": "./scripts/deploy.sh latest github-pages",
    "deploy:docker": "./scripts/deploy.sh latest docker-compose",
    "deploy:all": "./scripts/deploy.sh latest all",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:all": "rm -rf dist node_modules coverage test-results playwright-report"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/react": "^10.18.0",
    "@sentry/vite-plugin": "^10.18.0",
    "web-vitals": "^3.5.2",
    "mammoth": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.0.0",
    "terser": "^5.44.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.9",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^3.2.4",
    "workbox-webpack-plugin": "^7.3.0"
  }
}
