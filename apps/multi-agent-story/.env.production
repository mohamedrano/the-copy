# Production Environment Variables - Jules Platform

# Database Configuration
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DATABASE_URL=postgresql://jules_user:YOUR_SECURE_PASSWORD_HERE@postgres:5432/jules_db

# Redis Configuration
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_URL=redis://:YOUR_REDIS_PASSWORD_HERE@redis:6379

# Authentication & Security
JWT_SECRET=YOUR_32_CHAR_SECRET_KEY_HERE
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# Gemini AI Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash-exp

# API Configuration
NODE_ENV=production
PORT=8000
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Frontend Configuration
VITE_API_URL=https://api.your-domain.com
VITE_WS_URL=wss://api.your-domain.com
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Session Configuration
SESSION_SECRET=YOUR_SESSION_SECRET_HERE
SESSION_MAX_AGE=86400000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Sentry (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@your-domain.com
