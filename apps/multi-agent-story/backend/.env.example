# Production Environment Variables
# Copy this file to .env and fill in the actual values

# JWT Secret - MUST be set in production (minimum 32 characters)
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-32-chars

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/the_copy_db

# Redis
REDIS_URL=redis://localhost:6379

# CORS Origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5181,https://yourdomain.com

# Gemini AI API
GEMINI_API_KEY=your-gemini-api-key-here

# Server Configuration
PORT=8000
HOST=0.0.0.0
NODE_ENV=production

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=15m
