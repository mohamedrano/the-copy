{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "vite/client",
      "node",
      "./src/types/remotes"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/config/*": [
        "./src/config/*"
      ],
      "@the-copy/shared-ui": [
        "../../packages/shared-ui/src"
      ],
      "@the-copy/shared-ui/*": [
        "../../packages/shared-ui/src/*"
      ],
      "@the-copy/shared-types": [
        "../../packages/shared-types/src"
      ],
      "@the-copy/shared-types/*": [
        "../../packages/shared-types/src/*"
      ],
      "@the-copy/shared-utils": [
        "../../packages/shared-utils/src"
      ],
      "@the-copy/shared-utils/*": [
        "../../packages/shared-utils/src/*"
      ]
    }
  },
  "include": [
    "src/App.tsx",
    "src/App.test.tsx",
    "src/main.tsx",
    "src/components/common/**/*.ts",
    "src/components/common/**/*.tsx",
    "src/components/AppErrorFallback.tsx",
    "src/components/ErrorBoundary.tsx",
    "src/components/LoadingFallback.tsx",
    "src/components/layout/**/*.ts",
    "src/components/layout/**/*.tsx",
    "src/config/environment.ts",
    "src/config/index.ts",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/routes/**/*.ts",
    "src/routes/**/*.tsx",
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/types/**/*.d.ts"
  ],
  "files": [
    "src/types/remotes.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}