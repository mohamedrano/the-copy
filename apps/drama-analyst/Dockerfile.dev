# Multi-stage Dockerfile for Drama Analyst
# Optimized for security, performance, and multi-platform support

# =====================================================
# Base Stage
# =====================================================
FROM node:18-alpine AS base

# Install system dependencies and security updates
RUN apk add --no-cache \
    git \
    curl \
    bash \
    dumb-init \
    tini \
    && apk upgrade --no-cache \
    && rm -rf /var/cache/apk/*

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs \
    && adduser -S drama-user -u 1001

# Set working directory
WORKDIR /app

# Copy package files first for better caching
COPY package*.json ./
COPY tsconfig.json ./
COPY vite.config.ts ./

# =====================================================
# Dependencies Stage
# =====================================================
FROM base AS dependencies

# Install all dependencies (including dev dependencies)
RUN npm ci --prefer-offline --no-audit \
    && npm cache clean --force

# =====================================================
# Development Stage
# =====================================================
FROM dependencies AS development

# Copy source code
COPY --chown=drama-user:nodejs . .

# Change ownership of the app directory
RUN chown -R drama-user:nodejs /app

# Switch to non-root user
USER drama-user

# Expose development port
EXPOSE 5173

# Health check for development
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:5173/ || exit 1

# Start development server with dumb-init for proper signal handling
ENTRYPOINT ["dumb-init", "--"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# =====================================================
# Build Stage
# =====================================================
FROM dependencies AS build

# Copy source code
COPY --chown=drama-user:nodejs . .

# Switch to non-root user
USER drama-user

# Build the application with optimizations
ENV NODE_ENV=production
RUN npm run build

# =====================================================
# Backend Stage
# =====================================================
FROM node:18-alpine AS backend

# Install system dependencies
RUN apk add --no-cache \
    dumb-init \
    curl \
    && apk upgrade --no-cache

# Create non-root user
RUN addgroup -g 1001 -S nodejs \
    && adduser -S backend-user -u 1001

# Set working directory
WORKDIR /app

# Copy backend package files
COPY backend/package*.json ./

# Install backend dependencies
RUN npm ci --only=production --prefer-offline --no-audit \
    && npm cache clean --force

# Copy backend source code
COPY --chown=backend-user:nodejs backend/ .

# Switch to non-root user
USER backend-user

# Expose backend port
EXPOSE 3001

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:3001/health || exit 1

# Start backend with dumb-init
ENTRYPOINT ["dumb-init", "--"]
CMD ["npm", "start"]

# =====================================================
# Production Stage (Frontend)
# =====================================================
FROM nginx:1.25-alpine AS production

# Install additional tools and security updates
RUN apk add --no-cache \
    curl \
    dumb-init \
    && apk upgrade --no-cache \
    && rm -rf /var/cache/apk/*

# Create non-root user
RUN addgroup -g 1001 -S nginx \
    && adduser -S nginx-user -u 1001

# Copy built application from build stage
COPY --from=build --chown=nginx-user:nginx /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY --chown=nginx-user:nginx nginx.conf /etc/nginx/conf.d/default.conf

# Copy custom error pages
COPY --from=build --chown=nginx-user:nginx /app/dist/index.html /usr/share/nginx/html/404.html

# Create nginx cache directories
RUN mkdir -p /var/cache/nginx \
    && chown -R nginx-user:nginx /var/cache/nginx \
    && chown -R nginx-user:nginx /var/log/nginx \
    && chown -R nginx-user:nginx /etc/nginx/conf.d

# Switch to non-root user
USER nginx-user

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost/health || exit 1

# Start nginx with dumb-init for proper signal handling
ENTRYPOINT ["dumb-init", "--"]
CMD ["nginx", "-g", "daemon off;"]

# =====================================================
# Multi-service Stage (for docker-compose)
# =====================================================
FROM base AS multi-service

# Install all dependencies
RUN npm ci --prefer-offline --no-audit

# Copy source code
COPY --chown=drama-user:nodejs . .

# Switch to non-root user
USER drama-user

# Expose both ports
EXPOSE 5173 3001

# Start both frontend and backend
ENTRYPOINT ["dumb-init", "--"]
CMD ["sh", "-c", "npm run dev -- --host 0.0.0.0 & cd backend && npm start & wait"]
