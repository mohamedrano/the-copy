{
  "name": "the-copy-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The Copy - Monorepo for Arabic Screenplay Editor and Drama Analysis Tools",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter \"./apps/**\" --parallel run dev",
    "dev:basic": "pnpm --filter basic-editor run dev",
    "dev:drama": "pnpm --filter drama-analyst run dev",
    "dev:stations": "pnpm --filter stations run dev",
    "dev:story": "pnpm --filter multi-agent-story run dev",
    "build": "pnpm -r --filter \"./apps/**\" run build",
    "build:all": "pnpm -r run build",
    "build:basic": "pnpm --filter basic-editor run build",
    "build:drama": "pnpm --filter drama-analyst run build",
    "build:stations": "pnpm --filter stations run build",
    "build:story": "pnpm --filter multi-agent-story run build",
    "build:remotes": "pnpm run build:basic && pnpm run build:drama && pnpm run build:stations && pnpm run build:story",
    "web:assemble": "node tools/assemble-web.mjs",
    "web:dist": "pnpm run build:all && pnpm run web:assemble",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "clean:all": "pnpm -r exec rm -rf dist node_modules .turbo && rm -rf node_modules web",
    "type-check": "pnpm -r run type-check",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "test": "cd apps/the-copy && vitest",
    "test:changed": "cd apps/the-copy && vitest --changed --watch=false",
    "coverage": "cd apps/the-copy && vitest run --coverage.enabled --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reporter=text",
    "coverage:diff": "node scripts/changed-files-coverage.js",
    "coverage:enforce": "node scripts/enforce-coverage.js",
    "preview": "pnpm --filter @the-copy/the-copy run preview",
    "verify:all": "pnpm run type-check && pnpm run lint && pnpm run test",
    "dev:shell": "pnpm --filter @the-copy/the-copy run dev",
    "dev:all": "run-p dev:shell dev:basic dev:drama dev:stations dev:story",
    "build:shell": "pnpm --filter @the-copy/the-copy run build",
    "type-check:shell": "pnpm --filter @the-copy/the-copy run type-check",
    "test:shell": "pnpm --filter @the-copy/the-copy run test",
    "docker:build": "docker build -f Dockerfile . -t the-copy-app",
    "docker:run": "docker run -p 8080:80 the-copy-app"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@playwright/test": "^1.56.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "eslint-plugin-tsdoc": "^0.2.17",
    "globals": "^13.24.0",
    "lighthouse": "^13.0.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.56.1",
    "typescript": "^5.3.3",
    "wait-on": "^9.0.1",
    "zx": "^8.8.4"
  },
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.15",
    "nanoid": "^5.1.6"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  }
}