{
  "projectName": "the-copy",
  "version": "0.0.0",
  "description": "Arabic Screenplay Editor with AI Analysis Agents",
  "type": "React TypeScript SPA",
  "buildTool": "Vite",
  "packageManager": "npm",
  "entryPoints": {
    "main": "src/main.tsx",
    "app": "src/App.tsx"
  },
  "publicAPI": {
    "components": [
      {
        "name": "App",
        "file": "src/App.tsx",
        "type": "React Component",
        "exports": ["default"],
        "description": "Root application component with routing"
      },
      {
        "name": "ScreenplayEditor",
        "file": "src/components/editor/ScreenplayEditor.tsx",
        "type": "React Component",
        "exports": ["default"],
        "description": "Main screenplay editing interface with Arabic text processing"
      }
    ],
    "services": [
      {
        "name": "AnalysisService",
        "file": "src/services/AnalysisService.ts",
        "type": "Class",
        "exports": ["default", "AnalysisResult", "CharacterDialogueStat"],
        "description": "Core analytics service for screenplay analysis"
      },
      {
        "name": "InstructionsLoader",
        "file": "src/services/instructions-loader.ts",
        "type": "Service",
        "exports": ["instructionsLoader"],
        "description": "Dynamic instruction loading for AI agents"
      }
    ],
    "agents": [
      {
        "name": "AgentFacade",
        "file": "src/agents/core/index.ts",
        "type": "Facade",
        "exports": ["AGENT_CONFIGS", "getAgentsByCategory", "getAgentById", "AgentExecutor", "SimpleAgentExecutor"],
        "description": "Central hub for all agent configurations and execution"
      }
    ],
    "types": [
      {
        "name": "CoreTypes",
        "file": "src/types/types.ts",
        "type": "Type Definitions",
        "exports": ["TaskType", "TaskCategory", "AIAgentConfig", "Script", "Scene", "Character", "DialogueLine"],
        "description": "Core TypeScript types and interfaces"
      }
    ]
  },
  "moduleStructure": {
    "src/": {
      "components/": {
        "description": "React UI components",
        "critical": true,
        "files": [
          "App.tsx",
          "HomePage.tsx",
          "ProjectsPage.tsx",
          "TemplatesPage.tsx",
          "ExportPage.tsx",
          "SettingsPage.tsx",
          "editor/ScreenplayEditor.tsx"
        ]
      },
      "agents/": {
        "description": "AI agent implementations and configurations",
        "critical": true,
        "submodules": {
          "core/": "Core agent services and facades",
          "analysis/": "Analysis agents (character, dialogue, etc.)",
          "generation/": "Content generation agents",
          "transformation/": "Text transformation agents",
          "evaluation/": "Quality evaluation agents",
          "instructions/": "Agent instruction sets"
        }
      },
      "services/": {
        "description": "Business logic and external service integrations",
        "critical": true,
        "files": [
          "AnalysisService.ts",
          "instructions-loader.ts",
          "agent-instructions.ts"
        ]
      },
      "types/": {
        "description": "TypeScript type definitions",
        "critical": true,
        "files": ["types.ts"]
      },
      "config/": {
        "description": "Application configuration",
        "critical": false,
        "files": [
          "agents.ts",
          "environment.ts",
          "prompts.ts",
          "agentConfigs.ts"
        ]
      },
      "utils/": {
        "description": "Utility functions",
        "critical": false,
        "files": ["sanitizer.ts"]
      },
      "lib/": {
        "description": "External library integrations",
        "critical": false,
        "files": ["ai/geminiTypes.ts"]
      }
    }
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "@google/generative-ai": "^0.24.1",
    "dompurify": "^3.0.0",
    "lucide-react": "^0.544.0",
    "mammoth": "^1.11.0"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vite": "^7.1.7",
    "@vitejs/plugin-react": "^5.0.3",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "buildConfiguration": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "pathMapping": {
      "@/*": "src/*",
      "@/components/*": "src/components/*",
      "@/agents/*": "src/agents/*",
      "@/services/*": "src/services/*",
      "@/types/*": "src/types/*",
      "@/config/*": "src/config/*",
      "@/modules/*": "src/modules/*"
    }
  },
  "criticalModules": [
    "src/App.tsx",
    "src/components/editor/ScreenplayEditor.tsx",
    "src/services/AnalysisService.ts",
    "src/agents/core/index.ts",
    "src/types/types.ts"
  ],
  "documentationPriority": {
    "high": [
      "src/App.tsx",
      "src/components/editor/ScreenplayEditor.tsx",
      "src/services/AnalysisService.ts",
      "src/agents/core/index.ts",
      "src/types/types.ts"
    ],
    "medium": [
      "src/services/instructions-loader.ts",
      "src/agents/core/geminiService.ts",
      "src/agents/core/integratedAgent.ts"
    ],
    "low": [
      "src/config/*",
      "src/utils/*",
      "src/lib/*"
    ]
  }
}