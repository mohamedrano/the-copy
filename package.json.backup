{
  "name": "the-copy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "analyze": "vite-bundle-analyzer dist",
    "api:extract": "api-extractor run --local",
    "build": "tsc && vite build",
    "build:external": "node scripts/build-external-projects.js",
    "build:prod": "npm run build:external && npm run build",
    "ci:docs": "run-s type-check lint docs:verify linkcheck",
    "clean": "rm -rf dist public/drama-analyst public/stations public/multi-agent-story reports/build-logs",
    "clean:external": "rm -rf external/*/dist external/*/node_modules external/*/jules-frontend/dist external/*/jules-frontend/node_modules",
    "coverage": "vitest run --coverage.enabled --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reporter=text",
    "coverage:diff": "node scripts/changed-files-coverage.js",
    "coverage:enforce": "node scripts/enforce-coverage.js",
    "dev": "vite",
    "doc:build": "typedoc",
    "doc:coverage": "node scripts/doc-coverage.mjs",
    "doc:lint": "eslint --ext .ts,.tsx --rule 'tsdoc/syntax: error' 'src/**/*.{ts,tsx}'",
    "docker:build": "docker build -t the-copy:latest .",
    "docker:run": "docker run -p 8080:80 the-copy:latest",
    "docker:test": "docker run --rm -p 8080:80 the-copy:latest",
    "docs:verify": "run-p doc:lint doc:build api:extract type:coverage",
    "linkcheck": "markdown-link-check -q -c .mlc.config.json \"**/*.md\" > .reports/link-check.txt || true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prebuild:prod": "npm run type-check && npm run lint",
    "preview": "vite preview",
    "security-audit": "npm audit --audit-level moderate",
    "test": "vitest run",
    "test:changed": "vitest --changed --watch=false",
    "test:run": "vitest run",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "type:coverage": "type-coverage --detail --ignoreCatch",
    "verify:all": "npm run type-check && npm run lint && npm run test:run"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.8.3",
    "vite": "^7.1.7",
    "vite-bundle-analyzer": "^0.11.0",
    "vitest": "^2.0.0",
    "@playwright/test": "^1.44.0",
    "typedoc": "^0.25.0",
    "eslint-plugin-tsdoc": "^0.2.17",
    "@microsoft/api-extractor": "^7.40.0",
    "type-coverage": "^2.18.2",
    "markdown-link-check": "^3.11.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dompurify": "^3.0.0",
    "lucide-react": "^0.544.0",
    "mammoth": "^1.11.0",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "overrides": {
    "react": "19.1.1",
    "react-dom": {
      "react": "19.1.1"
    }
  }
}