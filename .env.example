# The Copy Monorepo - Environment Variables Template
# نسخ هذا الملف إلى .env وتعديل القيم حسب الحاجة

# ===== Gemini API Configuration =====
# مطلوب لتطبيقات Drama Analyst و Multi-Agent Story و Stations
VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Shell Configuration =====
VITE_SHELL_TITLE="The Copy — Unified Workspace"

# ===== Application URLs (Development) =====
# يمكن تغييرها للإشارة إلى منافذ أو خوادم مختلفة
VITE_EDITOR_URL=/basic-editor
VITE_DRAMA_URL=/drama-analyst
VITE_STATIONS_URL=/stations
VITE_AGENTS_URL=/multi-agent-story

# ===== Application URLs (Production) =====
# في الإنتاج، استخدم عناوين كاملة إذا كانت التطبيقات على خوادم منفصلة
# VITE_EDITOR_URL=https://editor.example.com
# VITE_DRAMA_URL=https://drama.example.com
# VITE_STATIONS_URL=https://stations.example.com
# VITE_AGENTS_URL=https://agents.example.com

# ===== Sentry Configuration (Optional) =====
# VITE_SENTRY_AUTH_TOKEN=your_sentry_auth_token
# VITE_SENTRY_DSN=your_sentry_dsn
# VITE_APP_VERSION=1.0.0

# ===== Node Environment =====
NODE_ENV=development
